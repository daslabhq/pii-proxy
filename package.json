{
  "name": "pii-proxy",
  "version": "0.2.0",
  "description": "Privacy proxy for AI agents. Mask PII before sending to LLMs, unmask responses to write back to real systems.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./learn": {
      "import": "./dist/learn.js",
      "types": "./dist/learn.d.ts"
    }
  },
  "bin": {
    "pii-proxy-learn": "./bin/learn.ts"
  },
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "learn": "bun run bin/learn.ts",
    "prepublishOnly": "tsc"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "pii",
    "privacy",
    "anonymization",
    "llm",
    "ai-agent",
    "masking",
    "gdpr"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daslabhq/pii-proxy.git"
  },
  "dependencies": {
    "@faker-js/faker": "^9.0.0",
    "gliner": "^0.0.19",
    "onnxruntime-node": "^1.26.0",
    "onnxruntime-web": "^1.26.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@types/bun": "latest",
    "typescript": "^5.5.0"
  }
}
